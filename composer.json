{
  "name": "kryptoexpress/kryptoexpress-php",
  "description": "Framework-agnostic PHP SDK for the KryptoExpress API.",
  "type": "library",
  "license": "MIT",
  "keywords": ["kryptoexpress", "crypto", "payments", "wallet", "sdk", "php"],
  "homepage": "https://kryptoexpress.pro",
  "support": {
    "issues": "https://github.com/kryptoexpress/kryptoexpress-php/issues",
    "source": "https://github.com/kryptoexpress/kryptoexpress-php"
  },
  "require": {
    "php": "^8.2",
    "ext-hash": "*",
    "ext-json": "*",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.1",
    "psr/http-message": "^2.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.80",
    "nyholm/psr7": "^1.8",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "KryptoExpress\\SDK\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "KryptoExpress\\SDK\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml.dist",
    "analyse": "phpstan analyse",
    "lint": "php-cs-fixer fix --dry-run --diff --allow-risky=yes",
    "format": "php-cs-fixer fix --allow-risky=yes"
  },
  "config": {
    "sort-packages": true,
    "platform": {
      "php": "8.2.0"
    },
    "allow-plugins": {
      "phpstan/extension-installer": false
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
